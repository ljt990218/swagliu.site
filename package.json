{
  "name": "nuxt-app",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint . --fix",
    "stylelint:fix": "npx stylelint **/*.{css,scss,vue,less,html} --fix"
  },
  "dependencies": {
    "@giscus/vue": "2.3.0",
    "@iconify-json/icon-park-outline": "1.1.12",
    "@iconify-json/simple-icons": "1.1.79",
    "@unocss/reset": "0.57.6",
    "date-fns": "2.30.0"
  },
  "devDependencies": {
    "@nuxt/content": "2.9.0",
    "@nuxtjs/stylelint-module": "5.1.0",
    "@types/node": "20.9.3",
    "@typescript-eslint/eslint-plugin": "5.62.0",
    "@typescript-eslint/parser": "5.62.0",
    "@unocss/nuxt": "0.57.6",
    "@vueuse/core": "10.6.1",
    "@vueuse/nuxt": "10.6.1",
    "eslint": "8.39.0",
    "eslint-plugin-vue": "9.17.0",
    "lint-staged": "15.1.0",
    "nuxt": "3.8.2",
    "postcss-html": "1.8.0",
    "postcss-scss": "4.0.9",
    "sass": "1.69.5",
    "simple-git-hooks": "2.9.0",
    "stylelint": "15.11.0",
    "stylelint-config-standard": "34.0.0",
    "typescript": "5.0.4"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "*.{css,scss,less,html}": [
      "stylelint --fix"
    ],
    "*.vue": [
      "eslint --fix",
      "stylelint --fix"
    ]
  }
}
